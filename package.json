{
  "name": "origintab",
  "private": true,
  "version": "1.1.3",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox --mv3 -c wxt.config.firefox.ts",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox --mv3 -c wxt.config.firefox.ts",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox --mv3 -c wxt.config.firefox.ts",
    "zip:all": "bun run --parallel zip zip:firefox",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "wxt prepare",
    "prepare": "husky"
  },
  "devDependencies": {
    "@lucide/svelte": "^1.7.0",
    "@tailwindcss/vite": "^4.2.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/luxon": "^3.7.1",
    "@types/sortablejs": "^1.15.9",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@wxt-dev/module-svelte": "^2.0.5",
    "daisyui": "^5.5.19",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "wxt": "^0.20.25"
  },
  "dependencies": {
    "dexie": "^4.4.2",
    "luxon": "^3.7.2",
    "sortablejs": "^1.15.7"
  },
  "lint-staged": {
    "*.{ts,svelte,html,css}": [
      "prettier --write"
    ]
  }
}
